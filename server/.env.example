PORT=4000
NODE_ENV=development

# Recipients for order notification emails, sent via Microsoft Graph (see GRAPH_SENDMAIL_USER_ID below)
BUSINESS_EMAIL=business@example.com
ORDERS_EMAIL=orders@example.com

# HIOBuy (server-side only — never expose to the Expo app; leave both keys unset to force mock mode)
HIOBUY_ENV=test
HIO_TEST_API_KEY=
HIO_LIVE_API_KEY=

# Microsoft Graph / SharePoint (server-side only — never expose to the Expo app)
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SITE_ID=
GRAPH_ORDERS_LIST_ID=
GRAPH_SENDMAIL_USER_ID=

# Pricing
MARKUP_PERCENTAGE=20
SERVICE_FEE_FIXED_USD=0

# Price-change absorption threshold at order-submission revalidation (plan §6):
# absorb upstream increases up to whichever is LOWER of the percent/USD threshold.
PRICE_INCREASE_ABSORB_THRESHOLD_PERCENT=3
PRICE_INCREASE_ABSORB_THRESHOLD_USD=3
PRICING_ROUNDING_PRECISION=2

# Delivery zones (Somaliland only at launch, plan §1/§6)
DELIVERY_ZONE_SOMALILAND_USD=15

# Cash/Zaad payment instructions (placeholders — real values supplied before launch, plan §11/§14)
ZAAD_NUMBER=
ZAAD_ACCOUNT_NAME=
CASH_CONTACT_NUMBER=
PAYMENT_DEADLINE_DAYS=7

# Currency provider (mock by default)
CURRENCY_PROVIDER=mock

# HIOBuy product cache (in-memory only, process-lifetime — all optional, sane defaults in code)
# CACHE_SEARCH_FRESH_MS=900000
# CACHE_SEARCH_STALE_MS=7200000
# CACHE_DETAIL_FRESH_MS=1800000
# CACHE_DETAIL_STALE_MS=14400000
# CACHE_HOME_FRESH_MS=21600000
# CACHE_HOME_STALE_MS=86400000
# CACHE_NEGATIVE_FRESH_MS=300000
# CACHE_QUOTA_WARNING_THRESHOLD=10
