{
  "name": "aa-catalog-server",
  "version": "1.0.0",
  "description": "Backend API for the aa-catalog app",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm install && tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "node --import tsx --experimental-test-module-mocks --test tests/**/*.test.ts",
    "tunnel": "ngrok http 4000"
  },
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "@types/nodemailer": "^8.0.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "isomorphic-fetch": "^3.0.0",
    "nodemailer": "^9.0.1",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsx": "^4.22.4"
  }
}
